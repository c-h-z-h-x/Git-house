# ── 环境变量配置 ──
# 复制此文件为 .env 并填入你的 API Key

# 通义千问 DashScope（推荐）
# 从 https://bailian.console.aliyun.com 获取 API Key
DASHSCOPE_API_KEY=your_api_key_here

# 通义千问工作空间地址（可选）
# 如果用工作空间 API Key（sk-ws-开头），需填写对应的地址
# 用普通 DashScope Key（sk-开头）则不用填，默认使用公共地址
# BAILIAN_BASE_URL=https://ws-xxx.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# OpenAI（可选）
OPENAI_API_KEY=your_api_key_here

# DeepSeek（可选）
DEEPSEEK_API_KEY=your_api_key_here
